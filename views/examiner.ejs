<!DOCTYPE html>
<html lang="en">
<%- include('layouts/head', { title: 'Examiner' }); -%>

  <body>
    <!-- Navigation-->
    <%- include('layouts/navbar'); -%>
      <!-- Page Header-->
      <header class="masthead">
        <div class="container position-relative px-4 px-lg-5">
          <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-8 col-xl-7">
              <div class="page-heading">
                <h1>Examiner</h1>
                <span class="subheading">DriveTest Booking Kiosk</span>
              </div>
            </div>
          </div>
        </div>
      </header>
      <!-- Filter Form -->
      <div class="container mt-3">
        <% if (error) { %><div class="alert alert-danger" role="alert"><%= error %></div><% } %>
        <form action="/examiner" method="GET">
          <label for="testType">Filter by Test Type:</label>
          <select class="form-select mb-3" id="testType" name="testType">
            <option value="all">All</option>
            <option value="G2">G2 Test</option>
            <option value="G">G Test</option>
          </select>

          <button type="submit" class="btn btn-primary">Apply Filter</button>
        </form>
      </div>

      <div class="container mt-5">
        <h2>Appointment List</h2>
        <h5>
          <%= message %>
        </h5>
        <div class="row align-items-end mb-3">
          <div class="col-md-6">
            <label for="examinerAppointmentSearch" class="form-label">Search appointments</label>
            <input type="search" class="form-control" id="examinerAppointmentSearch" placeholder="Name, vehicle, date, test type..." data-table-search="#examinerAppointments" data-count-target="#examinerAppointmentCount" />
          </div>
          <div class="col-md-6"><p class="mb-0 mt-2" id="examinerAppointmentCount" role="status"><%= appointments.length %> appointments shown</p></div>
        </div>
        <div class="table-responsive">
        <table class="table table-hover align-middle" id="examinerAppointments">
          <caption class="visually-hidden">Driver appointments assigned to the examiner</caption>
          <thead>
            <tr>
              <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="0">Name</button></th>
              <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="1">Car details</button></th>
              <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="2">Appointment date</button></th>
              <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="3">Appointment time</button></th>
              <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="4">Test type</button></th>
              <th scope="col">Remarks</th>
              <th scope="col">Action</th>
            </tr>
          </thead>
          <tbody>
            <% appointments.forEach(function(appointment) { %>
              <tr>
                <td>
                  <%= appointment.userDetails.firstName %>
                    <%= appointment.userDetails.lastName %>
                </td>
                <td>
                  <%= appointment.userDetails.carDetails.make %>
                    <%= appointment.userDetails.carDetails.model %>
                </td>
                <td>
                  <%= appointment.userDetails.appointmentDate %>
                </td>
                <td>
                  <%= appointment.userDetails.appointmentTime %>
                </td>
                <td>
                  <%= appointment.testType %>
                </td>
                <td>
                  <%= appointment.userDetails.comment %>
                </td>
                <td>
                  <a href="/examiner/appointments/<%= appointment.userDetails._id %>/<%= appointment.userDetails.testType %>"
                    class="btn btn-primary">View Details</a>
                </td>
              </tr>
              <% }); %>
          </tbody>
        </table>
        </div>
      </div>
      <!-- Footer-->
      <%- include('layouts/footer') -%>
        <!-- JS-->
        <%- include('layouts/scripts') -%>
  </body>

</html>
