<section class="card mt-4" aria-labelledby="appointment-history-heading">
  <div class="card-body">
    <h2 class="h4" id="appointment-history-heading">Test history</h2>
    <% const history = user.appointmentHistory || []; %>
    <% if (history.length) { %>
      <ul class="list-group list-group-flush">
        <% [...history].reverse().forEach(function(item) { %>
          <li class="list-group-item px-0">
            <div class="d-flex justify-content-between gap-3">
              <strong><%= item.testType %> test · <%= item.date %> at <%= item.time %></strong>
              <span class="badge <%= item.status === 'Passed' ? 'bg-success' : 'bg-danger' %>"><%= item.status %></span>
            </div>
            <% if (item.comment) { %><p class="mb-0 mt-2"><%= item.comment %></p><% } %>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <p class="mb-0 text-muted">Completed test results will appear here.</p>
    <% } %>
  </div>
</section>
