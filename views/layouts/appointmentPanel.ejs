<% const appointmentHeadingId = `${testType.toLowerCase()}-booking-heading`; %>
<% const dateField = testType === "G" ? "Gdate" : "G2date"; %>
<% const hasAppointment = user.testType === testType && user.appointmentDate; %>
<% if (hasAppointment || journey.canBook) { %>
<section aria-labelledby="<%= appointmentHeadingId %>">
  <h2 class="h4" id="<%= appointmentHeadingId %>"><%= testType %> appointment</h2>

  <% if (hasAppointment) { %>
    <div class="card mb-3">
      <div class="card-body">
        <p class="mb-1"><strong>Date:</strong> <%= user.appointmentDate %></p>
        <p class="mb-1"><strong>Time:</strong> <%= user.appointmentTime %></p>
        <p class="mb-0">
          <strong>Status:</strong>
          <span class="badge <%= user.status === 'Passed' ? 'bg-success' : user.status === 'Failed' ? 'bg-danger' : 'bg-warning text-dark' %>"><%= user.status %></span>
        </p>
        <% if (user.comment) { %>
          <p class="mt-3 mb-0"><strong>Examiner comment:</strong> <%= user.comment %></p>
        <% } %>

        <% if (user.status === "Pending") { %>
          <details class="mt-3">
            <summary class="btn btn-outline-primary">Reschedule</summary>
            <form action="/edit" method="POST" class="mt-3">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <input type="hidden" name="action" value="reschedule" />
              <input type="hidden" name="testType" value="<%= testType %>" />
              <div class="form-floating">
                <input type="date" name="<%= dateField %>" class="form-control" id="bookingAppointmentDate" onchange="getTimeSlot('<%- user._id %>')" required />
                <label for="bookingAppointmentDate">New <%= testType %> appointment date</label>
              </div>
              <p class="mt-3" id="headerTimeSlot" role="status" aria-live="polite">Choose a date to load available times.</p>
              <div class="mt-3" id="timeSlotsSection" hidden>
                <h3 class="h5">Select a time</h3>
                <div id="selectSlots"></div>
              </div>
              <button class="btn btn-primary mt-3" type="submit" disabled>Save new appointment</button>
            </form>
          </details>
          <form action="/edit" method="POST" class="mt-3" onsubmit="return confirm('Cancel this appointment?')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <input type="hidden" name="action" value="cancel" />
            <input type="hidden" name="testType" value="<%= testType %>" />
            <button class="btn btn-outline-danger" type="submit">Cancel appointment</button>
          </form>
        <% } %>
      </div>
    </div>
  <% } %>

  <% if (journey.canBook) { %>
    <form action="/edit" method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="testType" value="<%= testType %>" />
      <div class="form-floating">
        <input type="date" name="<%= dateField %>" class="form-control" id="bookingAppointmentDate" onchange="getTimeSlot('<%- user._id %>')" required />
        <label for="bookingAppointmentDate">Select <%= testType %> appointment date</label>
      </div>
      <p class="mt-3" id="headerTimeSlot" role="status" aria-live="polite">Choose a date to load available times.</p>
      <div class="mt-3" id="timeSlotsSection" hidden>
        <h3 class="h5">Select a time</h3>
        <div id="selectSlots"></div>
      </div>
      <button class="btn btn-primary mt-3" type="submit" disabled>Book <%= testType %> test</button>
    </form>
  <% } %>
</section>
<% } %>
