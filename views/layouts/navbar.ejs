              <%- currentPath === '/g2' ? 'aria-current="page"' : '' %>>G2 Test</a>
          </li>
          <li class="nav-item">
            <a class="nav-link px-lg-3 py-3 py-lg-4<%= currentPath === '/g' ? ' active' : '' %>" href="/g"
              <%- currentPath === '/g' ? 'aria-current="page"' : '' %>>G Test</a>
          </li>
        <% } else if (loggedIn && userType === 'admin') { %>
          <li class="nav-item">
            <a class="nav-link px-lg-3 py-3 py-lg-4<%= currentPath === '/appointment' ? ' active' : '' %>"
              href="/appointment" <%- currentPath === '/appointment' ? 'aria-current="page"' : '' %>>Availability</a>
          </li>
          <li class="nav-item">
            <a class="nav-link px-lg-3 py-3 py-lg-4<%= currentPath === '/checkDriverStatus' ? ' active' : '' %>"
