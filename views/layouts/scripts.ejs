<script>
  document.addEventListener("DOMContentLoaded", function () {
    const appointmentDate = document.getElementById("appointmentDate");
    if (!appointmentDate) return;
    appointmentDate.valueAsDate = new Date();
    appointmentDate.min = appointmentDate.value;

    async function updateTimeSlotAvailability() {
      try {
        document.querySelectorAll(".form-check-input").forEach((checkbox) => {
          checkbox.disabled = false;
        });

        const selectedDate = document.getElementById("appointmentDate").value;
        const response = await fetch(`checkAppointment/${selectedDate}`);

        if (response.ok) {
          const existingAppointments = await response.json();
          const times = existingAppointments.time;

          if (times) {
            times.forEach((appointment) => {
              const time = appointment;
              const checkbox = document.getElementById(time);

              if (checkbox) {
                checkbox.disabled = true;
              }
            });
          }
        } else {
          console.error(`Error fetching appointments: ${response.statusText}`);
        }
      } catch (error) {
        console.error("Fetch error:", error);
      }
    }

    updateTimeSlotAvailability();
    appointmentDate.addEventListener("change", updateTimeSlotAvailability);
  });
</script>
<script>
  async function getTimeSlot(sessionId) {
    const dateInput = document.getElementById("bookingAppointmentDate");
    const selectSlotList = document.getElementById("selectSlots");
    const timeSlotsSection = document.getElementById("timeSlotsSection");
    const headerTime = document.getElementById("headerTimeSlot");
    const form = dateInput.closest("form");
    const submitButton = form.querySelector('button[type="submit"]');
    const selectedDate = dateInput.value;

    selectSlotList.replaceChildren();
    timeSlotsSection.style.display = "none";
    submitButton.disabled = true;
    headerTime.textContent = "Loading available times...";

    try {
      const [response, bookedResponse] = await Promise.all([
        fetch(`/checkAppointment/${selectedDate}`),
        fetch(`/checkTimeSlotAvailable/${selectedDate}`),
      ]);

      if (response.status === 404) {
        headerTime.textContent = "No appointment times are offered for this date.";
        return;
      }
      if (!response.ok || !bookedResponse.ok) throw new Error("Unable to load appointments");

      const offered = (await response.json()).time || [];
      const booked = await bookedResponse.json();
      const available = offered.filter((slot) => !booked.some((item) =>
        item.time === slot && String(item.userId) !== String(sessionId)
      ));

      if (!available.length) {
        headerTime.textContent = "No available times remain for this date. Choose another date.";
        return;
      }

      available.forEach((slot) => {
        const taskDiv = document.createElement("div");
        const radioInput = document.createElement("input");
        const id = `slot-${slot.replace(":", "-")}`;
        taskDiv.className = "form-check form-check-inline";
        radioInput.className = "form-check-input";
        radioInput.type = "radio";
        radioInput.name = "timeSlot";
        radioInput.id = id;
        radioInput.value = slot;
        radioInput.required = true;
        const label = document.createElement("label");
        label.className = "form-check-label";
        label.htmlFor = id;
        label.textContent = slot;
        radioInput.addEventListener("change", () => { submitButton.disabled = false; });
        taskDiv.appendChild(radioInput);
        taskDiv.appendChild(label);
        selectSlotList.appendChild(taskDiv);
      });
      headerTime.textContent = "Choose an available time.";
      timeSlotsSection.style.display = "block";
    } catch (error) {
      headerTime.textContent = "Unable to load appointment times. Please try again.";
    }
  }
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {

    function getTodayDate() {

      const today = new Date();
      const year = today.getFullYear();
      const month = String(today.getMonth() + 1).padStart(2, "0");
      const day = String(today.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    }
  });
</script>
