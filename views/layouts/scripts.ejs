<script>
  document.addEventListener("DOMContentLoaded", function () {
    const appointmentDate = document.getElementById("appointmentDate");
    if (!appointmentDate) return;
    const slots = [...document.querySelectorAll(".appointment-slot")];
    const submitButton = document.getElementById("submitButton");
    const status = document.getElementById("slotManagementStatus");
    appointmentDate.valueAsDate = new Date();
    appointmentDate.min = appointmentDate.value;

    function updateSubmitButton() {
      submitButton.disabled = !slots.some((slot) => slot.checked && !slot.disabled);
    }

    async function updateTimeSlotAvailability() {
      slots.forEach((slot) => {
        slot.checked = false;
        slot.disabled = true;
      });
      updateSubmitButton();
      status.textContent = "Loading slot availability...";

      try {
        const response = await fetch(`/checkAppointment/${appointmentDate.value}`);
        if (!response.ok && response.status !== 404) throw new Error("Unable to load slots");
        const existing = response.ok ? (await response.json()).time || [] : [];

        slots.forEach((slot) => {
          const alreadyOffered = existing.includes(slot.value);
          const label = document.querySelector(`label[for="${slot.id}"]`);
          slot.disabled = alreadyOffered;
          label.classList.toggle("btn-outline-primary", !alreadyOffered);
          label.classList.toggle("btn-outline-secondary", alreadyOffered);
          label.querySelector(".slot-state").textContent = alreadyOffered ? "Already offered" : "Available to add";
        });
        status.textContent = existing.length
          ? `${existing.length} slot${existing.length === 1 ? " is" : "s are"} already offered. Select any new times to add.`
          : "No slots are offered yet. Select one or more times to add.";
      } catch (error) {
        status.textContent = "Unable to load availability. Choose the date again to retry.";
      }
    }

    updateTimeSlotAvailability();
    appointmentDate.addEventListener("change", updateTimeSlotAvailability);
    slots.forEach((slot) => slot.addEventListener("change", updateSubmitButton));
  });
</script>
<script>
  async function getTimeSlot(sessionId) {
    const dateInput = document.getElementById("bookingAppointmentDate");
    const selectSlotList = document.getElementById("selectSlots");
    const timeSlotsSection = document.getElementById("timeSlotsSection");
    const headerTime = document.getElementById("headerTimeSlot");
    const form = dateInput.closest("form");
    const submitButton = form.querySelector('button[type="submit"]');
    const selectedDate = dateInput.value;
    const setStatus = (message, tone) => {
      headerTime.textContent = message;
      headerTime.className = `alert alert-${tone} mt-3 mb-0`;
    };

    selectSlotList.replaceChildren();
    timeSlotsSection.hidden = true;
    submitButton.disabled = true;
    if (!selectedDate) {
      setStatus("Choose a date to load available times.", "secondary");
      return;
    }
    setStatus("Loading available times...", "info");

    try {
      const [response, bookedResponse] = await Promise.all([
        fetch(`/checkAppointment/${selectedDate}`),
        fetch(`/checkTimeSlotAvailable/${selectedDate}`),
      ]);

      if (response.status === 404) {
        setStatus("No appointment times are offered for this date. Choose another date.", "warning");
        return;
      }
      if (!response.ok || !bookedResponse.ok) throw new Error("Unable to load appointments");

      const offered = (await response.json()).time || [];
      const booked = await bookedResponse.json();
      let availableCount = 0;
      offered.forEach((slot) => {
        const available = !booked.some((item) =>
          item.time === slot && String(item.userId) !== String(sessionId)
        );
        if (available) availableCount += 1;

        const slotColumn = document.createElement("div");
        const radioInput = document.createElement("input");
        const id = `slot-${slot.replace(":", "-")}`;
        slotColumn.className = "col-6 col-sm-4";
        radioInput.className = "btn-check";
        radioInput.type = "radio";
        radioInput.name = "timeSlot";
        radioInput.id = id;
        radioInput.value = slot;
        radioInput.autocomplete = "off";
        radioInput.disabled = !available;
        radioInput.required = true;
        const label = document.createElement("label");
        label.className = `btn ${available ? "btn-outline-primary" : "btn-outline-secondary"} text-start w-100 h-100`;
        label.htmlFor = id;
        const time = document.createElement("strong");
        const state = document.createElement("span");
        time.className = "d-block";
        time.textContent = slot;
        state.className = "small";
        state.textContent = available ? "Available" : "Unavailable";
        label.appendChild(time);
        label.appendChild(state);
        radioInput.addEventListener("change", () => {
          submitButton.disabled = false;
          setStatus(`${slot} selected. Continue to confirm your appointment.`, "success");
        });
        slotColumn.appendChild(radioInput);
        slotColumn.appendChild(label);
        selectSlotList.appendChild(slotColumn);
      });

      timeSlotsSection.hidden = false;
      setStatus(
        availableCount
          ? `${availableCount} time${availableCount === 1 ? " is" : "s are"} available. Select one to continue.`
          : "No available times remain for this date. Choose another date.",
        availableCount ? "info" : "warning"
      );
    } catch (error) {
      setStatus("Unable to load appointment times. Please try again.", "danger");
    }
  }
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const collator = new Intl.Collator(undefined, { numeric: true, sensitivity: "base" });
    document.querySelectorAll("[data-table-search]").forEach((search) => {
      const table = document.querySelector(search.dataset.tableSearch);
      const rows = [...table.tBodies[0].rows];
      const count = document.querySelector(search.dataset.countTarget);

      search.addEventListener("input", () => {
        const query = search.value.trim().toLocaleLowerCase();
        let visible = 0;
        rows.forEach((row) => {
          row.hidden = !row.textContent.toLocaleLowerCase().includes(query);
          if (!row.hidden) visible += 1;
        });
        count.textContent = `${visible} appointment${visible === 1 ? "" : "s"} shown`;
      });

      table.querySelectorAll("[data-sort-column]").forEach((button) => {
        button.addEventListener("click", () => {
          const column = Number(button.dataset.sortColumn);
          const descending = button.closest("th").getAttribute("aria-sort") === "ascending";
          rows.sort((left, right) => collator.compare(
            left.cells[column].textContent.trim(),
            right.cells[column].textContent.trim()
          ) * (descending ? -1 : 1));
          table.querySelectorAll("th[aria-sort]").forEach((heading) => heading.setAttribute("aria-sort", "none"));
          button.closest("th").setAttribute("aria-sort", descending ? "descending" : "ascending");
          table.tBodies[0].append(...rows);
        });
      });
    });
  });
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {

    function getTodayDate() {

      const today = new Date();
      const year = today.getFullYear();
      const month = String(today.getMonth() + 1).padStart(2, "0");
      const day = String(today.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    }
  });
</script>
