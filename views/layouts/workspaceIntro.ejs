<section class="container mt-4" aria-labelledby="<%= id %>-heading">
  <div class="card bg-light border-0">
    <div class="card-body p-4 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
      <div>
        <p class="small text-uppercase fw-bold text-primary mb-1"><%= eyebrow %></p>
        <h2 class="h3 mb-2" id="<%= id %>-heading"><%= heading %></h2>
        <p class="text-muted mb-0"><%= description %></p>
      </div>
      <div class="d-flex flex-column flex-sm-row gap-2 flex-shrink-0">
        <a class="btn btn-primary" href="<%= primaryHref %>"><%= primaryLabel %></a>
        <% if (typeof secondaryHref !== "undefined" && secondaryHref) { %>
          <a class="btn btn-outline-primary" href="<%= secondaryHref %>"><%= secondaryLabel %></a>
        <% } %>
      </div>
    </div>
  </div>
</section>
