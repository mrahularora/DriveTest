<!DOCTYPE html>
<html lang="en">
<%- include('layouts/head', { title: 'G2 Test' }); -%>

  <body>
    <!-- Navigation-->
    <%- include('layouts/navbar'); -%>

      <!-- Page Header-->
      <header class="masthead">
        <div class="container position-relative px-4 px-lg-5">
          <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-8 col-xl-7">
              <div class="page-heading">
                <h1>G2 Test</h1>
                <span class="subheading">Book your G2 Test</span>
              </div>
            </div>
          </div>
        </div>
      </header>
      <!-- Main Content-->
      <main class="mb-4">
        <div class="container px-4 px-lg-5">
          <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-8 col-xl-7">
              <div class="my-1">
                <%- include('layouts/driverProgress') -%>
                <% if (error) { %>
                  <div class="alert alert-danger" role="alert"><%= error %></div>
                <% } %>
                <% if (success) { %>
                  <div class="alert alert-success" role="status"><%= success %></div>
                <% } %>
                <form action="/edit" method="POST" class="mb-5">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="action" value="profile" />
                  <h2 class="h4">Personal details</h2>
                  <div class="form-floating"><input class="form-control" id="firstname" name="firstName" value="<%- user.firstName === 'default' ? '' : user.firstName %>" required /><label for="firstname">First name</label></div>
                  <div class="form-floating"><input class="form-control" id="lastname" name="lastName" value="<%- user.lastName === 'default' ? '' : user.lastName %>" required /><label for="lastname">Last name</label></div>
                  <div class="form-floating"><input class="form-control" id="LicenseNo" name="licenceNo" value="<%- user.licenceNo === 'default' ? '' : user.licenceNo %>" minlength="8" maxlength="8" pattern="[A-Za-z0-9]{8}" required /><label for="LicenseNo">Licence number</label></div>
                  <div class="form-floating"><input class="form-control" id="Age" name="age" type="number" min="16" max="100" value="<%- user.age || '' %>" required /><label for="Age">Age</label></div>
                  <div class="form-floating"><input class="form-control" id="dob" name="dob" type="date" value="<%- user.dob ? user.dob.toISOString().slice(0, 10) : '' %>" required /><label for="dob">Date of birth</label></div>

                  <h2 class="h4 mt-4">Vehicle details</h2>
                  <div class="form-floating"><input class="form-control" id="make" name="make" value="<%- user.carDetails.make === 'default' ? '' : user.carDetails.make %>" required /><label for="make">Make</label></div>
                  <div class="form-floating"><input class="form-control" id="model" name="model" value="<%- user.carDetails.model === 'default' ? '' : user.carDetails.model %>" required /><label for="model">Model</label></div>
                  <div class="form-floating"><input class="form-control" id="year" name="year" type="number" min="1900" value="<%- user.carDetails.year || '' %>" required /><label for="year">Year</label></div>
                  <div class="form-floating"><input class="form-control" id="plateno" name="plateNo" value="<%- user.carDetails.plateNo === 'default' ? '' : user.carDetails.plateNo %>" required /><label for="plateno">Plate number</label></div>
                  <button class="btn btn-primary mt-3" type="submit">Save profile</button>
                </form>

                <section aria-labelledby="g2-booking-heading">
                  <h2 class="h4" id="g2-booking-heading">G2 appointment</h2>
                  <% if (user.testType === "G2" && user.appointmentDate) { %>
                    <div class="card mb-3"><div class="card-body">
                      <p class="mb-1"><strong>Date:</strong> <%= user.appointmentDate %></p>
                      <p class="mb-1"><strong>Time:</strong> <%= user.appointmentTime %></p>
                      <p class="mb-0"><strong>Status:</strong> <span class="badge <%= user.status === 'Passed' ? 'bg-success' : user.status === 'Failed' ? 'bg-danger' : 'bg-warning text-dark' %>"><%= user.status %></span></p>
                      <% if (user.comment) { %><p class="mt-3 mb-0"><strong>Examiner comment:</strong> <%= user.comment %></p><% } %>
                    </div></div>
                  <% } %>

                  <% if (journey.canBook) { %>
                    <form action="/edit" method="POST">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <input type="hidden" name="testType" value="G2" />
                      <div class="form-floating">
                        <input type="date" name="G2date" class="form-control" id="bookingAppointmentDate" onchange="getTimeSlot('<%- user._id %>')" required />
                        <label for="bookingAppointmentDate">Select G2 appointment date</label>
                      </div>
                      <p class="mt-3" id="headerTimeSlot" role="status" aria-live="polite">Choose a date to load available times.</p>
                      <div class="mt-3" id="timeSlotsSection" style="display: none">
                        <h3 class="h5">Select a time</h3>
                        <div id="selectSlots"></div>
                      </div>
                      <button class="btn btn-primary mt-3" type="submit" disabled>Book G2 test</button>
                    </form>
                  <% } %>
                </section>
              </div>
            </div>
          </div>
        </div>
      </main>
    <!-- Footer-->
    <%- include('layouts/footer') -%>
    <!-- JS-->
    <%- include('layouts/scripts') -%>
  </body>
  <script type="text/javascript">
    $(function () {
      var dtToday = new Date();

      var month = dtToday.getMonth() + 1;
      var day = dtToday.getDate();
      var year = dtToday.getFullYear();
      if (month < 10) month = "0" + month.toString();
      if (day < 10) day = "0" + day.toString();
      var maxDate = year + "-" + month + "-" + day;
      $("#bookingAppointmentDate").attr("min", maxDate);
    });
  </script>
</html>
