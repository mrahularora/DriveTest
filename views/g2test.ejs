<!DOCTYPE html>
<html lang="en">
<%- include('layouts/head', { title: 'G2 Test' }); -%>

  <body>
    <!-- Navigation-->
    <%- include('layouts/navbar'); -%>

      <%- include('layouts/pageHeader', { heading: 'G2 test', description: 'Complete your profile and manage your G2 appointment.' }); -%>
      <!-- Main Content-->
      <main class="mb-4">
        <div class="container px-4 px-lg-5">
          <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-8 col-xl-7">
              <div class="my-1">
                <%- include('layouts/driverProgress') -%>
                <% if (error) { %>
                  <div class="alert alert-danger" role="alert"><%= error %></div>
                <% } %>
                <% if (success) { %>
                  <div class="alert alert-success" role="status"><%= success %></div>
                <% } %>
                <form action="/edit" method="POST" class="mb-5">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <input type="hidden" name="action" value="profile" />
                  <section class="card mb-4" aria-labelledby="personal-details-heading">
                    <div class="card-body">
                      <h2 class="h4" id="personal-details-heading">Personal and licence details</h2>
                      <div class="row g-3">
                        <div class="col-md-6"><div class="form-floating"><input class="form-control" id="firstname" name="firstName" value="<%- user.firstName === 'default' ? '' : user.firstName %>" required /><label for="firstname">First name</label></div></div>
                        <div class="col-md-6"><div class="form-floating"><input class="form-control" id="lastname" name="lastName" value="<%- user.lastName === 'default' ? '' : user.lastName %>" required /><label for="lastname">Last name</label></div></div>
                        <div class="col-md-6"><div class="form-floating"><input class="form-control" id="LicenseNo" name="licenceNo" value="<%- user.licenceNo === 'default' ? '' : user.licenceNo %>" minlength="8" maxlength="8" pattern="[A-Za-z0-9]{8}" required /><label for="LicenseNo">Licence number</label></div></div>
                        <div class="col-md-6"><div class="form-floating"><input class="form-control" id="Age" name="age" type="number" min="16" max="100" value="<%- user.age || '' %>" required /><label for="Age">Age</label></div></div>
                        <div class="col-12"><div class="form-floating"><input class="form-control" id="dob" name="dob" type="date" value="<%- user.dob ? user.dob.toISOString().slice(0, 10) : '' %>" required /><label for="dob">Date of birth</label></div></div>
                      </div>
                    </div>
                  </section>

                  <section class="card" aria-labelledby="vehicle-details-heading">
                    <div class="card-body">
                      <h2 class="h4" id="vehicle-details-heading">Vehicle details</h2>
                      <div class="row g-3">
                        <div class="col-md-6"><div class="form-floating"><input class="form-control" id="make" name="make" value="<%- user.carDetails.make === 'default' ? '' : user.carDetails.make %>" required /><label for="make">Make</label></div></div>
                        <div class="col-md-6"><div class="form-floating"><input class="form-control" id="model" name="model" value="<%- user.carDetails.model === 'default' ? '' : user.carDetails.model %>" required /><label for="model">Model</label></div></div>
                        <div class="col-md-6"><div class="form-floating"><input class="form-control" id="year" name="year" type="number" min="1900" value="<%- user.carDetails.year || '' %>" required /><label for="year">Year</label></div></div>
                        <div class="col-md-6"><div class="form-floating"><input class="form-control" id="plateno" name="plateNo" value="<%- user.carDetails.plateNo === 'default' ? '' : user.carDetails.plateNo %>" required /><label for="plateno">Plate number</label></div></div>
                      </div>
                      <button class="btn btn-primary mt-3" type="submit">Save profile</button>
                    </div>
                  </section>
                </form>

                <%- include('layouts/appointmentPanel', { testType: 'G2' }) -%>
                <%- include('layouts/appointmentHistory') -%>
              </div>
            </div>
          </div>
        </div>
      </main>
    <!-- Footer-->
    <%- include('layouts/footer') -%>
    <!-- JS-->
    <%- include('layouts/scripts') -%>
  </body>
  <script type="text/javascript">
    $(function () {
      var dtToday = new Date();

      var month = dtToday.getMonth() + 1;
      var day = dtToday.getDate();
      var year = dtToday.getFullYear();
      if (month < 10) month = "0" + month.toString();
      if (day < 10) day = "0" + day.toString();
      var maxDate = year + "-" + month + "-" + day;
      $("#bookingAppointmentDate").attr("min", maxDate);
    });
  </script>
</html>
