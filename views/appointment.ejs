<!DOCTYPE html>
<html lang="en">
  <%- include('layouts/head', { title: 'Appointments' }); -%>

  <body>
    <!-- Navigation-->
    <%- include('layouts/navbar'); -%>

    <!-- Page Header-->
    <header class="masthead">
      <div class="container position-relative px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
          <div class="col-md-10 col-lg-8 col-xl-7">
            <div class="page-heading">
              <h1>Appointment</h1>
              <span class="subheading">DriveTest Booking Kiosk</span>
            </div>
          </div>
        </div>
      </div>
    </header>
    <div class="container mt-5">
      <h2>Add Appointment Availability</h2>
      <% if (typeof error !== 'undefined' && error.length > 1){ %>
      <div class="alert alert-danger" role="alert"><%= error %></div>
      <% }else{ %>
      <p>Select appointment slots for a specific date</p>
      <% } %>
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success" role="status"><%= message %></div>
      <% } %>

      <form action="/admin/appointments/" method="post" id="slotManagementForm">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-floating mb-3">
          <input type="date" name="date" class="form-control" id="appointmentDate" required />
          <label for="appointmentDate">Appointment date</label>
        </div>
        <p id="slotManagementStatus" class="mb-3" role="status" aria-live="polite">Choose a date to review its availability.</p>
        <% ["Morning", "Afternoon"].forEach(function(period) { %>
          <fieldset class="mb-4">
            <legend class="h5"><%= period %></legend>
            <div class="row g-3">
              <% slots.filter((slot) => slot.period === period).forEach(function(slot) { %>
                <div class="col-6 col-md-4">
                  <input class="btn-check appointment-slot" type="checkbox" name="time" value="<%= slot.value %>" id="slot-<%= slot.value.replace(':', '') %>" autocomplete="off" disabled />
                  <label class="btn btn-outline-primary text-start w-100 h-100 p-3" for="slot-<%= slot.value.replace(':', '') %>">
                    <strong class="d-block"><%= slot.label %></strong>
                    <span class="slot-state small">Available to add</span>
                  </label>
                </div>
              <% }); %>
            </div>
          </fieldset>
        <% }); %>
        <button class="btn btn-primary" id="submitButton" type="submit" disabled>Add selected slots</button>
      </form>
    </div>
    <%- include('layouts/footer') -%>
    <!-- JS-->
    <%- include('layouts/scripts') -%>
  </body>
</html>
