<!DOCTYPE html>
<html lang="en">
<%- include('layouts/head', { title: 'Sign Up' }); -%>

  <body>
    <!-- Navigation-->
    <%- include('layouts/navbar'); -%>
      <%- include('layouts/pageHeader', { heading: 'Create an account', description: 'Register as a driver to manage your road tests.' }); -%>
      <!-- Main Content-->
      <main class="mb-4">
        <div class="container px-4 px-lg-5">
          <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-8 col-xl-6">
              <% if (typeof error !=='undefined' && error.length> 1){ %>
                <div class="alert alert-danger" role="alert"><%= error %></div>
                <% }else{ %>
                  <h2>Account details</h2>
                  <% } %>

                    <div class="my-4">
                      <form id="registrationForm" method="post" action="/users/register">
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <div class="form-floating">
                          <input class="form-control" id="username" name="userName" type="text" placeholder="Username"
                            autocomplete="username" required />
                          <label for="username">Username</label>
                          <div class="usernameError"></div>
                        </div>
                        <div class="form-floating">
                          <input class="form-control" id="password" name="password" type="password"
                            placeholder="Enter your password" minlength="8" autocomplete="new-password" required />
                          <label for="password">Password</label>
                          <div class="passwordError"></div>
                        </div>
                        <div class="form-floating">
                          <input class="form-control" id="confirmPassword" name="confirmPassword" type="password"
                            placeholder="Confirm your password" minlength="8" autocomplete="new-password" required />
                          <label for="confirmPassword">Confirm Password</label>
                          <div class="confirmPasswordError"></div>
                        </div>
                        <p class="text-muted mt-3">New accounts are created for drivers.</p>
                        <div class="form-actions">
                          <button class="btn btn-primary text-uppercase" id="submitButton" type="submit">
                            Create account
                          </button>
                          <a href="/login">Already have an account?</a>
                        </div>
                      </form>
                    </div>
            </div>
          </div>
        </div>
      </main>
      <!-- Footer-->
      <%- include('layouts/footer') -%>
        <!-- JS-->
        <%- include('layouts/scripts') -%>
  </body>

</html>
