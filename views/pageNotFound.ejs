  <!DOCTYPE html>
  <html lang="en">
  <%- include('layouts/head', { title: typeof title === 'undefined' ? 'Page Not Found' : title }); -%>

    <body>
      <!-- Navigation-->
      <%- include('layouts/navbar'); -%>

        <%- include('layouts/pageHeader', { heading: typeof title === 'undefined' ? 'Page not found' : title, description: 'We could not open the page you requested.' }); -%>

    <!-- Page Content -->
    <main class="container text-center mt-5">
        <p class="lead">
          <%= typeof message === 'undefined' ? "The page you're looking for does not exist." : message %>
        </p>
        <hr class="my-4" />
        <p>Return to the <a href="/">Dashboard</a></p>
    </main>

    <!-- Footer -->
    <%- include('layouts/footer') -%>

    <!-- JS -->
    <%- include('./layouts/scripts') -%>
  </body>
</html>
