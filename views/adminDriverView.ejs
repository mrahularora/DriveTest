<!DOCTYPE html>
<html lang="en">

<%- include('layouts/head', { title: 'Driver Status' }); -%>

<body>
    <!-- Navigation-->
    <%- include('layouts/navbar'); -%>
        <%- include('layouts/pageHeader', { heading: 'Administrator workspace', description: 'Driver results and licensing.' }); -%>
        <%- include('layouts/workspaceIntro', {
            id: 'licensing-intro',
            eyebrow: 'Licensing',
            heading: 'Issue licences from completed results',
            description: 'Review passed and failed road tests, then open eligible records to issue a licence.',
            primaryHref: '#adminAppointments',
            primaryLabel: 'Review driver results',
            secondaryHref: '/appointment',
            secondaryLabel: 'Manage availability'
        }); -%>

        <div class="container mt-5">
            <h2>Completed assessments</h2>
            <% if (error) { %><div class="alert alert-danger" role="alert"><%= error %></div><% } %>
            <h5>
                <%= message %>
            </h5>
            <div class="row align-items-end mb-3">
                <div class="col-md-6">
                    <label for="adminAppointmentSearch" class="form-label">Search appointments</label>
                    <input type="search" class="form-control" id="adminAppointmentSearch" placeholder="Name, vehicle, date, status..." data-table-search="#adminAppointments" data-count-target="#adminAppointmentCount" />
                </div>
                <div class="col-md-6"><p class="mb-0 mt-2" id="adminAppointmentCount" role="status"><%= appointments.length %> appointments shown</p></div>
            </div>
            <div class="table-responsive">
            <table class="table table-hover align-middle" id="adminAppointments">
                <caption class="visually-hidden">Driver appointment results and licence actions</caption>
                <thead>
                    <tr>
                        <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="0">Name</button></th>
                        <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="1">Car details</button></th>
                        <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="2">Appointment date</button></th>
                        <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="3">Appointment time</button></th>
                        <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="4">Test type</button></th>
                        <th scope="col">Remarks</th>
                        <th scope="col" aria-sort="none"><button type="button" class="btn btn-link p-0 fw-bold text-dark text-decoration-none" data-sort-column="6">Status</button></th>
                        <th scope="col">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% appointments.forEach(function(appointment) { %>
                        <tr>
                            <td>
                                <%= appointment.userDetails.firstName %>
                                    <%= appointment.userDetails.lastName %>
                            </td>
                            <td>
                                <%= appointment.userDetails.carDetails.make %>
                                    <%= appointment.userDetails.carDetails.model %>
                            </td>
                            <td>
                                <%= appointment.userDetails.appointmentDate %>
                            </td>
                            <td>
                                <%= appointment.userDetails.appointmentTime %>
                            </td>
                            <td>
                                <%= appointment.testType %>
                            </td>
                            <td>
                                <%= appointment.userDetails.comment %>
                            </td>
                            <td>
                                <% if (appointment.userDetails.status === 'Pending') { %>
                                    <span class="badge bg-info text-dark">Pending</span>
                                <% } else if (appointment.userDetails.pass === true) { %>
                                    <span class="badge bg-success">Passed</span>
                                <% } else { %>
                                    <span class="badge bg-danger">Failed</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (appointment.userDetails.pass === true) { %>
                                    <a href="/admin/vendor/<%= appointment.userDetails._id %>/<%= appointment.userDetails.testType %>"
                                        class="btn btn-primary btn-sm">Issue licence</a>
                                <% } else { %>
                                    <span class="text-muted" aria-label="No action available">&mdash;</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
            </div>
        </div>
        <!-- Footer-->
        <%- include('layouts/footer') -%>
        <!-- JS-->
        <%- include('layouts/scripts') -%>
</body>

</html>
