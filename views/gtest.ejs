<!DOCTYPE html>
<html lang="en">
<%- include('layouts/head', { title: 'G Test' }); -%>

  <body>
    <%- include('layouts/navbar'); -%>
    <%- include('layouts/pageHeader', { heading: 'G test', description: 'Review your eligibility and manage your full G appointment.' }); -%>

    <main class="mb-4">
      <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
          <div class="col-md-10 col-lg-8 col-xl-7">
            <div class="my-1">
              <%- include('layouts/driverProgress') -%>
              <% if (error) { %>
                <div class="alert alert-danger" role="alert"><%= error %></div>
              <% } %>
              <% if (success) { %>
                <div class="alert alert-success" role="status"><%= success %></div>
              <% } %>

              <div id="user-info" class="mb-5">
                <h2 class="h4">Driver information</h2>
                <p class="mb-1"><strong>Name:</strong> <%= user.firstName %> <%= user.lastName %></p>
                <p class="mb-1"><strong>Age:</strong> <%= user.age %></p>
                <p><strong>Licence number:</strong> <%= user.licenceNo %></p>

                <h2 class="h4 mt-4">Vehicle details</h2>
                <p class="mb-1"><strong>Make and model:</strong> <%= user.carDetails.make %> <%= user.carDetails.model %></p>
                <p><strong>Year and plate:</strong> <%= user.carDetails.year %> · <%= user.carDetails.plateNo %></p>

                <details>
                  <summary class="btn btn-outline-primary">Update vehicle details</summary>
                  <form action="/edit" method="POST" class="mt-3">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="action" value="car" />
                    <div class="form-floating">
                      <input class="form-control" id="carMake" name="make" value="<%- user.carDetails.make %>" required />
                      <label for="carMake">Make</label>
                    </div>
                    <div class="form-floating">
                      <input class="form-control" id="carModel" name="model" value="<%- user.carDetails.model %>" required />
                      <label for="carModel">Model</label>
                    </div>
                    <div class="form-floating">
                      <input class="form-control" id="carYear" name="year" type="number" min="1900"
                        value="<%- user.carDetails.year %>" required />
                      <label for="carYear">Year</label>
                    </div>
                    <div class="form-floating">
                      <input class="form-control" id="carPlate" name="plateNo" value="<%- user.carDetails.plateNo %>" required />
                      <label for="carPlate">Plate number</label>
                    </div>
                    <button class="btn btn-primary mt-3" type="submit">Save vehicle details</button>
                  </form>
                </details>
              </div>

              <%- include('layouts/appointmentPanel', { testType: 'G' }) -%>
              <%- include('layouts/appointmentHistory') -%>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('layouts/footer') -%>
    <%- include('layouts/scripts') -%>
    <script>
      $(function () {
        var dtToday = new Date();
        var month = dtToday.getMonth() + 1;
        var day = dtToday.getDate();
        var year = dtToday.getFullYear();
        if (month < 10) month = "0" + month.toString();
        if (day < 10) day = "0" + day.toString();
        var maxDate = year + "-" + month + "-" + day;
        $("#bookingAppointmentDate").attr("min", maxDate);
      });
    </script>
  </body>
</html>
