<!DOCTYPE html>
<html lang="en">
<%- include('layouts/head', { title: 'G Test' }); -%>

  <body>
    <%- include('layouts/navbar'); -%>
    <%- include('layouts/pageHeader', { heading: 'G test', description: 'Review your eligibility and manage your full G appointment.' }); -%>

    <main class="mb-4">
      <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
          <div class="col-md-10 col-lg-8 col-xl-7">
            <div class="my-1">
              <%- include('layouts/driverProgress') -%>
              <% if (error) { %>
                <div class="alert alert-danger" role="alert"><%= error %></div>
              <% } %>
              <% if (success) { %>
                <div class="alert alert-success" role="status"><%= success %></div>
              <% } %>

              <div id="user-info" class="row g-4 mb-5">
                <section class="col-md-6" aria-labelledby="driver-details-heading">
                  <div class="card h-100">
                    <div class="card-body">
                      <h2 class="h4" id="driver-details-heading">Personal and licence details</h2>
                      <dl class="row g-3 mb-0">
                        <div class="col-12"><dt class="small text-muted">Full name</dt><dd class="mb-0"><%= user.firstName %> <%= user.lastName %></dd></div>
                        <div class="col-sm-6"><dt class="small text-muted">Age</dt><dd class="mb-0"><%= user.age %></dd></div>
                        <div class="col-sm-6"><dt class="small text-muted">Licence number</dt><dd class="mb-0"><%= user.licenceNo %></dd></div>
                      </dl>
                    </div>
                  </div>
                </section>

                <section class="col-md-6" aria-labelledby="g-vehicle-details-heading">
                  <div class="card h-100">
                    <div class="card-body">
                      <h2 class="h4" id="g-vehicle-details-heading">Vehicle details</h2>
                      <dl class="row g-3">
                        <div class="col-12"><dt class="small text-muted">Make and model</dt><dd class="mb-0"><%= user.carDetails.make %> <%= user.carDetails.model %></dd></div>
                        <div class="col-sm-6"><dt class="small text-muted">Year</dt><dd class="mb-0"><%= user.carDetails.year %></dd></div>
                        <div class="col-sm-6"><dt class="small text-muted">Plate number</dt><dd class="mb-0"><%= user.carDetails.plateNo %></dd></div>
                      </dl>

                      <details>
                        <summary class="btn btn-outline-primary">Update vehicle details</summary>
                        <form action="/edit" method="POST" class="mt-3">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <input type="hidden" name="action" value="car" />
                          <div class="form-floating">
                            <input class="form-control" id="carMake" name="make" value="<%- user.carDetails.make %>" required />
                            <label for="carMake">Make</label>
                          </div>
                          <div class="form-floating">
                            <input class="form-control" id="carModel" name="model" value="<%- user.carDetails.model %>" required />
                            <label for="carModel">Model</label>
                          </div>
                          <div class="form-floating">
                            <input class="form-control" id="carYear" name="year" type="number" min="1900"
                              value="<%- user.carDetails.year %>" required />
                            <label for="carYear">Year</label>
                          </div>
                          <div class="form-floating">
                            <input class="form-control" id="carPlate" name="plateNo" value="<%- user.carDetails.plateNo %>" required />
                            <label for="carPlate">Plate number</label>
                          </div>
                          <button class="btn btn-primary mt-3" type="submit">Save vehicle details</button>
                        </form>
                      </details>
                    </div>
                  </div>
                </section>
              </div>

              <%- include('layouts/appointmentPanel', { testType: 'G' }) -%>
              <%- include('layouts/appointmentHistory') -%>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('layouts/footer') -%>
    <%- include('layouts/scripts') -%>
  </body>
</html>
